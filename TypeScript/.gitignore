dist/
build/
out/

# =========================
# Environment Variables
# =========================
# STRICTLY ignore all .env files to protect your API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# EXCEPTION: Always track the example file so others know what keys are needed
!.env.example

